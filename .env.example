# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=auth_db

# JWT Configuration
# The secret key must be at least 256 bits (32 characters) for HS256
JWT_SECRET_KEY=your_very_secure_secret_key_at_least_32_chars
JWT_ISSUER=AuthSystem
JWT_AUDIENCE=AuthSystem.Client
